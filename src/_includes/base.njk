<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title }} | Flake & Flake Attorneys at Law</title>
<meta name="description" content="{{ description | default('Flake & Flake — Estate Planning, Probate, Personal Injury, and Federal Civil Litigation in Henderson & Las Vegas, Nevada.') }}"/>
<meta property="og:title" content="{{ title }} | Flake & Flake"/>
<meta property="og:description" content="{{ description | default('Plan for the inevitable and recover from the unexpected.') }}"/>
<link rel="canonical" href="https://flakeandflake.com{{ page.url }}"/>
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        "surface": "#f8fafb",
        "surface-dim": "#d8dadb",
        "surface-container": "#eceeef",
        "surface-container-low": "#f2f4f5",
        "surface-container-high": "#e6e8e9",
        "surface-container-highest": "#e1e3e4",
        "surface-container-lowest": "#ffffff",
        "on-surface": "#191c1d",
        "on-surface-variant": "#43474e",
        "primary": "#001831",
        "primary-container": "#0d2d4d",
        "on-primary": "#ffffff",
        "on-primary-container": "#7a95bb",
        "secondary": "#5b5f61",
        "secondary-container": "#e0e3e5",
        "outline": "#74777f",
        "outline-variant": "#c3c6cf",
        "tertiary": "#271200",
        "tertiary-container": "#442400",
        "tertiary-fixed-dim": "#f6bb84",
      },
      fontFamily: {
        "headline": ["Newsreader", "serif"],
        "body": ["Manrope", "sans-serif"],
        "label": ["Manrope", "sans-serif"]
      },
      borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
    },
  },
}
</script>
<style>
.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}
.editorial-shadow {
  box-shadow: 0 24px 48px -12px rgba(0, 24, 49, 0.06);
}
.glass-panel {
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
</style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">

{% include "header.njk" %}

<main>
{{ content | safe }}
</main>

{% include "footer.njk" %}

</body>
</html>
